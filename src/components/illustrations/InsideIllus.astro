---
import illus from '../../content/illus.json';
import { type Locale, DEFAULT_LOCALE } from '../../lib/i18n';

interface Props {
  idx: 1 | 2 | 3 | 4 | 5 | 6;
}
const { idx } = Astro.props;
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = illus[locale];
---

<div class="ins-illus">
  {idx === 1 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="20" y="22" width="140" height="96" rx="6" class="str sfs" />
      <rect x="32" y="38" width="28" height="42" class="str thin" fill="var(--accent-soft)" />
      <rect x="36" y="44" width="5" height="5" class="p-f" />
      <rect x="44" y="44" width="5" height="5" class="p-f" />
      <rect x="52" y="44" width="5" height="5" class="p-f" />
      <rect x="36" y="54" width="5" height="5" class="p-f" />
      <rect x="44" y="54" width="5" height="5" class="p-f" />
      <rect x="52" y="54" width="5" height="5" class="p-f" />
      <rect x="36" y="64" width="5" height="5" class="p-f" />
      <rect x="44" y="64" width="5" height="5" class="p-f" />
      <rect x="52" y="64" width="5" height="5" class="p-f" />
      <line x1="68" y1="42" x2="146" y2="42" class="str thin" />
      <line x1="68" y1="50" x2="126" y2="50" class="str thin" />
      <rect x="68" y="60" width="22" height="16" rx="2" class="p-f" opacity="0.1" />
      <text x="79" y="72" class="val" text-anchor="middle">26</text>
      <rect x="94" y="60" width="22" height="16" rx="2" class="acc-f" opacity="0.2" />
      <text x="105" y="72" class="val val-a" text-anchor="middle">{t.value_short}</text>
      <rect x="120" y="60" width="22" height="16" rx="2" class="p-f" opacity="0.1" />
      <text x="131" y="72" class="val" text-anchor="middle" fill="var(--danger)">3</text>
      <rect x="32" y="92" width="120" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="32" y="92" width="78" height="8" rx="4" class="acc-f" />
      <text x="32" y="114" class="tag" font-size="8">{t.progress}</text>
    </svg>
  )}

  {idx === 2 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="20" y="14" width="140" height="30" rx="4" class="str sfs" />
      <rect x="28" y="23" width="14" height="12" class="p-f" opacity="0.2" />
      <path d="M 31 29 L 34 32 L 39 26" stroke="var(--primary)" stroke-width="1.5" fill="none" />
      <line x1="48" y1="26" x2="120" y2="26" class="str thin" />
      <line x1="48" y1="33" x2="100" y2="33" class="str thin" stroke-opacity="0.5" />
      <rect x="128" y="24" width="26" height="12" rx="6" class="ok-f" />
      <text x="141" y="33" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif" text-anchor="middle">{t.status.ok}</text>

      <rect x="20" y="54" width="140" height="30" rx="4" class="str sfs" />
      <rect x="28" y="63" width="14" height="12" class="acc-f" opacity="0.3" />
      <path d="M 35 65 L 35 73 M 31 69 L 39 69" class="str acc" stroke-width="1.5" />
      <line x1="48" y1="66" x2="115" y2="66" class="str thin" />
      <line x1="48" y1="73" x2="90" y2="73" class="str thin" stroke-opacity="0.5" />
      <rect x="128" y="64" width="26" height="12" rx="6" class="wa-f" />
      <text x="141" y="73" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif" text-anchor="middle">?</text>

      <rect x="20" y="94" width="140" height="30" rx="4" class="str sfs" />
      <rect x="28" y="103" width="14" height="12" class="p-f" opacity="0.2" />
      <line x1="31" y1="107" x2="39" y2="107" class="str thin" />
      <line x1="31" y1="111" x2="39" y2="111" class="str thin" />
      <line x1="48" y1="106" x2="125" y2="106" class="str thin" />
      <line x1="48" y1="113" x2="95" y2="113" class="str thin" stroke-opacity="0.5" />
      <rect x="128" y="104" width="26" height="12" rx="6" class="ok-f" />
      <text x="141" y="113" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif" text-anchor="middle">{t.status.ok}</text>
    </svg>
  )}

  {idx === 3 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="14" y="16" width="152" height="118" rx="4" class="str sfs" />
      <rect x="14" y="16" width="152" height="18" class="p-f" />
      <text x="26" y="28" class="tag" fill="#fff" font-size="8">{t.headers.material}</text>
      <text x="100" y="28" class="tag" fill="#fff" text-anchor="middle" font-size="8">{t.headers.norm}</text>
      <text x="146" y="28" class="tag" fill="#fff" text-anchor="middle" font-size="8">{t.headers.fact}</text>
      <line x1="14" y1="52" x2="166" y2="52" class="str thin" stroke-opacity="0.3" />
      <line x1="14" y1="70" x2="166" y2="70" class="str thin" stroke-opacity="0.3" />
      <line x1="14" y1="88" x2="166" y2="88" class="str thin" stroke-opacity="0.3" />
      <line x1="14" y1="106" x2="166" y2="106" class="str thin" stroke-opacity="0.3" />
      <line x1="78" y1="34" x2="78" y2="134" class="str thin" stroke-opacity="0.3" />
      <line x1="122" y1="34" x2="122" y2="134" class="str thin" stroke-opacity="0.3" />
      <line x1="22" y1="45" x2="68" y2="45" class="str thin" />
      <text x="100" y="48" class="val" text-anchor="middle">220</text>
      <text x="146" y="48" class="val val-a" text-anchor="middle">184</text>
      <line x1="22" y1="63" x2="68" y2="63" class="str thin" />
      <text x="100" y="66" class="val" text-anchor="middle">80</text>
      <text x="146" y="66" class="val" text-anchor="middle">69</text>
      <line x1="22" y1="81" x2="68" y2="81" class="str thin" />
      <text x="100" y="84" class="val" text-anchor="middle">540</text>
      <text x="146" y="84" class="val" text-anchor="middle" fill="var(--success)">540</text>
      <line x1="22" y1="99" x2="68" y2="99" class="str thin" />
      <text x="100" y="102" class="val" text-anchor="middle">120</text>
      <text x="146" y="102" class="val" text-anchor="middle" fill="var(--danger)">94</text>
      <line x1="22" y1="117" x2="68" y2="117" class="str thin" />
      <text x="100" y="120" class="val" text-anchor="middle">45</text>
      <text x="146" y="120" class="val" text-anchor="middle">45</text>
    </svg>
  )}

  {idx === 4 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <line x1="20" y1="78" x2="160" y2="78" class="str thin" stroke-opacity="0.4" />
      <g transform="translate(30, 78)">
        <circle cx="0" cy="0" r="6" class="p-f" />
        <rect x="-18" y="12" width="36" height="22" rx="3" class="str thin sfs" />
        <text x="0" y="27" class="tag" text-anchor="middle" font-size="9">04.04</text>
      </g>
      <g transform="translate(62, 78)">
        <circle cx="0" cy="0" r="6" class="p-f" />
        <rect x="-18" y="-34" width="36" height="22" rx="3" class="str thin sfs" />
        <text x="0" y="-19" class="tag" text-anchor="middle" font-size="9">09.04</text>
      </g>
      <g transform="translate(94, 78)">
        <circle cx="0" cy="0" r="7" class="acc-f" />
        <rect x="-22" y="12" width="44" height="22" rx="3" class="acc-f" opacity="0.3" />
        <rect x="-22" y="12" width="44" height="22" rx="3" class="str acc" />
        <text x="0" y="27" class="tag" fill="var(--accent)" text-anchor="middle" font-size="9">14.04</text>
      </g>
      <g transform="translate(126, 78)">
        <circle cx="0" cy="0" r="6" class="p-f" opacity="0.6" />
        <rect x="-18" y="-34" width="36" height="22" rx="3" class="str thin sfs" />
        <text x="0" y="-19" class="tag" text-anchor="middle" font-size="9">18.04</text>
      </g>
      <g transform="translate(156, 78)">
        <circle cx="0" cy="0" r="4" class="dim-f" />
      </g>
      <text x="90" y="20" class="tag" text-anchor="middle" font-size="9">{t.inflow_period}</text>
    </svg>
  )}

  {idx === 5 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <text x="8" y="26" class="tag" font-size="10">{t.materials[0]}</text>
      <rect x="72" y="20" width="68" height="9" rx="4.5" class="dim-f" opacity="0.4" />
      <rect x="72" y="20" width="58" height="9" rx="4.5" class="p-f" />
      <text x="172" y="28" class="val" font-size="11" text-anchor="end">184</text>

      <text x="8" y="50" class="tag" font-size="10">{t.materials[1]}</text>
      <rect x="72" y="44" width="68" height="9" rx="4.5" class="dim-f" opacity="0.4" />
      <rect x="72" y="44" width="44" height="9" rx="4.5" class="p-f" />
      <text x="172" y="52" class="val" font-size="11" text-anchor="end">142</text>

      <text x="8" y="74" class="tag" font-size="10">{t.materials[2]}</text>
      <rect x="72" y="68" width="68" height="9" rx="4.5" class="dim-f" opacity="0.4" />
      <rect x="72" y="68" width="24" height="9" rx="4.5" class="acc-f" />
      <text x="172" y="76" class="val val-a" font-size="11" text-anchor="end">62</text>

      <text x="8" y="98" class="tag" font-size="10">{t.materials[3]}</text>
      <rect x="72" y="92" width="68" height="9" rx="4.5" class="dim-f" opacity="0.4" />
      <rect x="72" y="92" width="10" height="9" rx="4.5" class="er-f" />
      <text x="172" y="100" class="val" font-size="11" text-anchor="end" fill="var(--danger)">12</text>

      <text x="8" y="122" class="tag" font-size="10">{t.materials[4]}</text>
      <rect x="72" y="116" width="68" height="9" rx="4.5" class="dim-f" opacity="0.4" />
      <rect x="72" y="116" width="36" height="9" rx="4.5" class="p-f" opacity="0.7" />
      <text x="172" y="124" class="val" font-size="11" text-anchor="end">98</text>
    </svg>
  )}

  {idx === 6 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <circle cx="50" cy="75" r="30" class="str thin" stroke-opacity="0.3" />
      <circle cx="50" cy="75" r="30" fill="none" stroke="var(--primary)" stroke-width="8" stroke-dasharray="120 188" stroke-dashoffset="0" transform="rotate(-90 50 75)" />
      <circle cx="50" cy="75" r="30" fill="none" stroke="var(--accent)" stroke-width="8" stroke-dasharray="50 188" stroke-dashoffset="-120" transform="rotate(-90 50 75)" />
      <circle cx="50" cy="75" r="30" fill="none" stroke="var(--danger)" stroke-width="8" stroke-dasharray="18 188" stroke-dashoffset="-170" transform="rotate(-90 50 75)" />
      <text x="50" y="73" text-anchor="middle" class="val" font-size="13">{t.value_short}</text>
      <text x="50" y="85" text-anchor="middle" class="tag" font-size="8" opacity="0.7">€</text>
      <rect x="98" y="34" width="72" height="22" rx="3" fill="var(--surface)" class="str thin" />
      <text x="104" y="48" class="tag" font-size="8">{t.status.ok}</text>
      <text x="164" y="48" class="val" text-anchor="end">84%</text>
      <rect x="98" y="62" width="72" height="22" rx="3" fill="var(--surface)" class="str thin" />
      <text x="104" y="76" class="tag" font-size="8" fill="var(--warn)">{t.status.warn}</text>
      <text x="164" y="76" class="val" text-anchor="end" fill="var(--warn)">11%</text>
      <rect x="98" y="90" width="72" height="22" rx="3" fill="var(--surface)" class="str thin" />
      <text x="104" y="104" class="tag" font-size="8" fill="var(--danger)">{t.status.err}</text>
      <text x="164" y="104" class="val" text-anchor="end" fill="var(--danger)">5%</text>
    </svg>
  )}
</div>

<style>
  .ins-illus { width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; }
  .ins-illus svg { width: 100%; height: 100%; }
  .ins-illus :global(.str) { stroke: var(--primary); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .ins-illus :global(.thin) { stroke-width: 1.5; }
  .ins-illus :global(.acc) { stroke: var(--accent); }
  .ins-illus :global(.acc-f) { fill: var(--accent); }
  .ins-illus :global(.p-f) { fill: var(--primary); }
  .ins-illus :global(.dim-f) { fill: var(--line); }
  .ins-illus :global(.sfs) { fill: var(--surface); }
  .ins-illus :global(.ok-f) { fill: var(--success); }
  .ins-illus :global(.wa-f) { fill: var(--warn); }
  .ins-illus :global(.er-f) { fill: var(--danger); }
  .ins-illus :global(.tag) { font-family: 'Roboto Condensed', ui-sans-serif, sans-serif; font-size: 9px; font-weight: 700; fill: var(--primary); letter-spacing: 0.05em; }
  .ins-illus :global(.val) { font-family: 'Roboto Condensed', ui-sans-serif, sans-serif; font-size: 10px; font-weight: 700; fill: var(--primary); }
  .ins-illus :global(.val-a) { fill: var(--accent); }
</style>
