---
interface Props {
  idx: 1 | 2 | 3 | 4 | 5 | 6;
}
const { idx } = Astro.props;
---

<div class="ins-illus">
  {idx === 1 && (
    <svg viewBox="0 0 180 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="20" y="20" width="140" height="100" rx="6" class="str sfs" />
      <rect x="32" y="38" width="28" height="42" class="str thin" fill="var(--accent-soft)" />
      <rect x="36" y="44" width="5" height="5" class="p-f" />
      <rect x="44" y="44" width="5" height="5" class="p-f" />
      <rect x="52" y="44" width="5" height="5" class="p-f" />
      <rect x="36" y="54" width="5" height="5" class="p-f" />
      <rect x="44" y="54" width="5" height="5" class="p-f" />
      <rect x="52" y="54" width="5" height="5" class="p-f" />
      <rect x="36" y="64" width="5" height="5" class="p-f" />
      <rect x="44" y="64" width="5" height="5" class="p-f" />
      <rect x="52" y="64" width="5" height="5" class="p-f" />
      <line x1="68" y1="40" x2="146" y2="40" class="str thin" />
      <line x1="68" y1="48" x2="126" y2="48" class="str thin" />
      <rect x="68" y="58" width="22" height="16" rx="2" class="p-f" opacity="0.1" />
      <text x="79" y="70" class="val" text-anchor="middle">26</text>
      <rect x="94" y="58" width="22" height="16" rx="2" class="acc-f" opacity="0.2" />
      <text x="105" y="70" class="val val-a" text-anchor="middle">128k</text>
      <rect x="120" y="58" width="22" height="16" rx="2" class="p-f" opacity="0.1" />
      <text x="131" y="70" class="val" text-anchor="middle" fill="var(--danger)">3</text>
      <rect x="32" y="96" width="120" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="32" y="96" width="78" height="8" rx="4" class="acc-f" />
      <text x="32" y="118" class="tag" font-size="8">ПРОГРЕСС 65%</text>
    </svg>
  )}

  {idx === 2 && (
    <svg viewBox="0 0 180 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="20" y="26" width="140" height="28" rx="4" class="str sfs" />
      <rect x="28" y="34" width="14" height="12" class="p-f" opacity="0.2" />
      <path d="M 31 40 L 34 43 L 39 37" stroke="var(--primary)" stroke-width="1.5" fill="none" />
      <line x1="48" y1="37" x2="120" y2="37" class="str thin" />
      <line x1="48" y1="44" x2="100" y2="44" class="str thin" stroke-opacity="0.5" />
      <rect x="130" y="36" width="22" height="10" rx="5" class="ok-f" />
      <text x="141" y="43" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif" text-anchor="middle">OK</text>

      <rect x="20" y="60" width="140" height="28" rx="4" class="str sfs" />
      <rect x="28" y="68" width="14" height="12" class="acc-f" opacity="0.3" />
      <path d="M 35 70 L 35 78 M 31 74 L 39 74" class="str acc" stroke-width="1.5" />
      <line x1="48" y1="71" x2="115" y2="71" class="str thin" />
      <line x1="48" y1="78" x2="90" y2="78" class="str thin" stroke-opacity="0.5" />
      <rect x="130" y="70" width="22" height="10" rx="5" class="wa-f" />
      <text x="141" y="77" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif" text-anchor="middle">?</text>

      <rect x="20" y="94" width="140" height="28" rx="4" class="str sfs" />
      <rect x="28" y="102" width="14" height="12" class="p-f" opacity="0.2" />
      <line x1="31" y1="106" x2="39" y2="106" class="str thin" />
      <line x1="31" y1="110" x2="39" y2="110" class="str thin" />
      <line x1="48" y1="105" x2="125" y2="105" class="str thin" />
      <line x1="48" y1="112" x2="95" y2="112" class="str thin" stroke-opacity="0.5" />
      <rect x="130" y="104" width="22" height="10" rx="5" class="ok-f" />
      <text x="141" y="111" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif" text-anchor="middle">OK</text>
    </svg>
  )}

  {idx === 3 && (
    <svg viewBox="0 0 180 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="16" y="20" width="148" height="100" rx="4" class="str sfs" />
      <rect x="16" y="20" width="148" height="16" class="p-f" />
      <text x="28" y="31" class="tag" fill="#fff">МАТЕРІАЛ</text>
      <text x="96" y="31" class="tag" fill="#fff" text-anchor="middle">НОРМА</text>
      <text x="142" y="31" class="tag" fill="#fff" text-anchor="middle">ФАКТ</text>
      <line x1="16" y1="52" x2="164" y2="52" class="str thin" stroke-opacity="0.3" />
      <line x1="16" y1="68" x2="164" y2="68" class="str thin" stroke-opacity="0.3" />
      <line x1="16" y1="84" x2="164" y2="84" class="str thin" stroke-opacity="0.3" />
      <line x1="16" y1="100" x2="164" y2="100" class="str thin" stroke-opacity="0.3" />
      <line x1="74" y1="36" x2="74" y2="120" class="str thin" stroke-opacity="0.3" />
      <line x1="118" y1="36" x2="118" y2="120" class="str thin" stroke-opacity="0.3" />
      <line x1="22" y1="45" x2="68" y2="45" class="str thin" />
      <text x="96" y="48" class="val" text-anchor="middle">220</text>
      <text x="142" y="48" class="val val-a" text-anchor="middle">184</text>
      <line x1="22" y1="61" x2="68" y2="61" class="str thin" />
      <text x="96" y="64" class="val" text-anchor="middle">80</text>
      <text x="142" y="64" class="val" text-anchor="middle">69</text>
      <line x1="22" y1="77" x2="68" y2="77" class="str thin" />
      <text x="96" y="80" class="val" text-anchor="middle">540</text>
      <text x="142" y="80" class="val" text-anchor="middle" fill="var(--success)">540</text>
      <line x1="22" y1="93" x2="68" y2="93" class="str thin" />
      <text x="96" y="96" class="val" text-anchor="middle">120</text>
      <text x="142" y="96" class="val" text-anchor="middle" fill="var(--danger)">94</text>
      <line x1="22" y1="109" x2="68" y2="109" class="str thin" />
      <text x="96" y="112" class="val" text-anchor="middle">45</text>
      <text x="142" y="112" class="val" text-anchor="middle">45</text>
    </svg>
  )}

  {idx === 4 && (
    <svg viewBox="0 0 180 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <line x1="20" y1="70" x2="160" y2="70" class="str thin" stroke-opacity="0.4" />
      <g transform="translate(30, 70)">
        <circle cx="0" cy="0" r="6" class="p-f" />
        <rect x="-18" y="12" width="36" height="22" rx="3" class="str thin sfs" />
        <text x="0" y="27" class="tag" text-anchor="middle" font-size="9">04.04</text>
      </g>
      <g transform="translate(62, 70)">
        <circle cx="0" cy="0" r="6" class="p-f" />
        <rect x="-18" y="-34" width="36" height="22" rx="3" class="str thin sfs" />
        <text x="0" y="-19" class="tag" text-anchor="middle" font-size="9">09.04</text>
      </g>
      <g transform="translate(94, 70)">
        <circle cx="0" cy="0" r="7" class="acc-f" />
        <rect x="-22" y="12" width="44" height="22" rx="3" class="acc-f" opacity="0.3" />
        <rect x="-22" y="12" width="44" height="22" rx="3" class="str acc" />
        <text x="0" y="27" class="tag" fill="var(--accent)" text-anchor="middle" font-size="9">14.04</text>
      </g>
      <g transform="translate(126, 70)">
        <circle cx="0" cy="0" r="6" class="p-f" opacity="0.6" />
        <rect x="-18" y="-34" width="36" height="22" rx="3" class="str thin sfs" />
        <text x="0" y="-19" class="tag" text-anchor="middle" font-size="9">18.04</text>
      </g>
      <g transform="translate(156, 70)">
        <circle cx="0" cy="0" r="4" class="dim-f" />
      </g>
      <text x="90" y="18" class="tag" text-anchor="middle" font-size="10">ПРИХІД ЗА ПЕРІОД</text>
    </svg>
  )}

  {idx === 5 && (
    <svg viewBox="0 0 180 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <text x="20" y="28" class="tag" font-size="9">Гіпсокартон</text>
      <rect x="78" y="22" width="80" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="78" y="22" width="68" height="8" rx="4" class="p-f" />
      <text x="152" y="28" class="val" font-size="10" text-anchor="end">184</text>

      <text x="20" y="48" class="tag" font-size="9">Профіль CW</text>
      <rect x="78" y="42" width="80" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="78" y="42" width="52" height="8" rx="4" class="p-f" />
      <text x="152" y="48" class="val" font-size="10" text-anchor="end">142</text>

      <text x="20" y="68" class="tag" font-size="9">Шпаклівка</text>
      <rect x="78" y="62" width="80" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="78" y="62" width="30" height="8" rx="4" class="acc-f" />
      <text x="152" y="68" class="val val-a" font-size="10" text-anchor="end">62</text>

      <text x="20" y="88" class="tag" font-size="9">Цемент М500</text>
      <rect x="78" y="82" width="80" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="78" y="82" width="14" height="8" rx="4" class="er-f" />
      <text x="152" y="88" class="val" font-size="10" text-anchor="end" fill="var(--danger)">12</text>

      <text x="20" y="108" class="tag" font-size="9">Арматура 12</text>
      <rect x="78" y="102" width="80" height="8" rx="4" class="dim-f" opacity="0.4" />
      <rect x="78" y="102" width="42" height="8" rx="4" class="p-f" opacity="0.7" />
      <text x="152" y="108" class="val" font-size="10" text-anchor="end">98</text>
    </svg>
  )}

  {idx === 6 && (
    <svg viewBox="0 0 180 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="52" cy="70" r="30" class="str thin" stroke-opacity="0.3" />
      <circle cx="52" cy="70" r="30" fill="none" stroke="var(--primary)" stroke-width="8" stroke-dasharray="120 188" stroke-dashoffset="0" transform="rotate(-90 52 70)" />
      <circle cx="52" cy="70" r="30" fill="none" stroke="var(--accent)" stroke-width="8" stroke-dasharray="50 188" stroke-dashoffset="-120" transform="rotate(-90 52 70)" />
      <circle cx="52" cy="70" r="30" fill="none" stroke="var(--danger)" stroke-width="8" stroke-dasharray="18 188" stroke-dashoffset="-170" transform="rotate(-90 52 70)" />
      <text x="52" y="68" text-anchor="middle" class="val" font-size="12">128k</text>
      <text x="52" y="80" text-anchor="middle" class="tag" font-size="8" opacity="0.7">€</text>
      <rect x="100" y="32" width="66" height="20" rx="3" fill="var(--surface)" class="str thin" />
      <text x="106" y="45" class="tag" font-size="8">OK</text>
      <text x="158" y="45" class="val" text-anchor="end">84%</text>
      <rect x="100" y="58" width="66" height="20" rx="3" fill="var(--surface)" class="str thin" />
      <text x="106" y="71" class="tag" font-size="8" fill="var(--warn)">РОЗХОД</text>
      <text x="158" y="71" class="val" text-anchor="end" fill="var(--warn)">11%</text>
      <rect x="100" y="84" width="66" height="20" rx="3" fill="var(--surface)" class="str thin" />
      <text x="106" y="97" class="tag" font-size="8" fill="var(--danger)">ПОМИЛКА</text>
      <text x="158" y="97" class="val" text-anchor="end" fill="var(--danger)">5%</text>
    </svg>
  )}
</div>

<style>
  .ins-illus { width: 100%; display: flex; justify-content: center; align-items: center; }
  .ins-illus svg { width: 100%; max-width: 260px; height: auto; }
  .ins-illus :global(.str) { stroke: var(--primary); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .ins-illus :global(.thin) { stroke-width: 1.5; }
  .ins-illus :global(.acc) { stroke: var(--accent); }
  .ins-illus :global(.acc-f) { fill: var(--accent); }
  .ins-illus :global(.p-f) { fill: var(--primary); }
  .ins-illus :global(.dim-f) { fill: var(--line); }
  .ins-illus :global(.sfs) { fill: var(--surface); }
  .ins-illus :global(.ok-f) { fill: var(--success); }
  .ins-illus :global(.wa-f) { fill: var(--warn); }
  .ins-illus :global(.er-f) { fill: var(--danger); }
  .ins-illus :global(.tag) { font-family: 'Roboto Condensed', ui-sans-serif, sans-serif; font-size: 9px; font-weight: 700; fill: var(--primary); letter-spacing: 0.05em; }
  .ins-illus :global(.val) { font-family: 'Roboto Condensed', ui-sans-serif, sans-serif; font-size: 10px; font-weight: 700; fill: var(--primary); }
  .ins-illus :global(.val-a) { fill: var(--accent); }
</style>
