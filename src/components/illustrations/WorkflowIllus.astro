---
import illus from '../../content/illus.json';
import { type Locale, DEFAULT_LOCALE } from '../../lib/i18n';

interface Props {
  step: 1 | 2 | 3 | 4 | 5;
}
const { step } = Astro.props;
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = illus[locale];
---

<div class="wf-illus">
  {step === 1 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="30" y="40" width="60" height="80" rx="4" class="str sfs" />
      <rect x="40" y="30" width="60" height="80" rx="4" class="str sfs" />
      <rect x="50" y="20" width="60" height="80" rx="4" class="str sfs" />
      <path d="M 96 20 L 110 20 L 110 34 Z" class="str acc" fill="var(--accent-soft)" />
      <line x1="56" y1="40" x2="100" y2="40" class="str thin" />
      <line x1="56" y1="50" x2="90" y2="50" class="str thin" />
      <line x1="56" y1="60" x2="100" y2="60" class="str thin" />
      <line x1="56" y1="70" x2="80" y2="70" class="str thin" />
      <circle cx="140" cy="80" r="18" class="str acc" fill="var(--accent-soft)" />
      <path d="M 140 72 L 140 88 M 134 78 L 140 72 L 146 78" class="str acc" stroke-width="2" />
      <rect x="14" y="100" width="52" height="18" rx="9" class="acc-f" />
      <text x="40" y="112" class="tag" fill="#fff" text-anchor="middle">{t.docs_badge}</text>
    </svg>
  )}

  {step === 2 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="40" y="20" width="110" height="100" rx="4" class="str sfs" />
      <line x1="52" y1="36" x2="138" y2="36" class="str thin" stroke-opacity="0.3" />
      <circle cx="58" cy="44" r="5" class="ok-f" />
      <path d="M 55 44 L 57.5 46.5 L 61 42.5" stroke="#fff" stroke-width="1.5" fill="none" />
      <line x1="70" y1="44" x2="130" y2="44" class="str thin" />
      <circle cx="58" cy="60" r="5" class="ok-f" />
      <path d="M 55 60 L 57.5 62.5 L 61 58.5" stroke="#fff" stroke-width="1.5" fill="none" />
      <line x1="70" y1="60" x2="125" y2="60" class="str thin" />
      <circle cx="58" cy="76" r="5" class="wa-f" />
      <text x="58" y="79.5" text-anchor="middle" fill="#fff" font-size="7" font-weight="700" font-family="sans-serif">!</text>
      <line x1="70" y1="76" x2="120" y2="76" class="str thin" stroke="var(--warn)" />
      <circle cx="58" cy="92" r="5" class="ok-f" />
      <path d="M 55 92 L 57.5 94.5 L 61 90.5" stroke="#fff" stroke-width="1.5" fill="none" />
      <line x1="70" y1="92" x2="128" y2="92" class="str thin" />
      <circle cx="58" cy="108" r="5" class="er-f" />
      <path d="M 56 106 L 60 110 M 60 106 L 56 110" stroke="#fff" stroke-width="1.5" />
      <line x1="70" y1="108" x2="115" y2="108" class="str thin" stroke="var(--danger)" />
      <circle cx="145" cy="76" r="13" class="str acc" fill="var(--accent-soft)" />
      <line x1="154" y1="85" x2="161" y2="92" class="str acc" stroke-width="3" />
    </svg>
  )}

  {step === 3 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="14" y="35" width="48" height="64" rx="3" class="str sfs" />
      <line x1="22" y1="48" x2="54" y2="48" class="str thin" />
      <line x1="22" y1="56" x2="48" y2="56" class="str thin" />
      <line x1="22" y1="64" x2="54" y2="64" class="str thin" />
      <path d="M 66 70 L 98 70 M 92 64 L 100 70 L 92 76" class="str acc" stroke-width="2.5" />
      <rect x="104" y="35" width="62" height="70" rx="4" class="str sfs" />
      <line x1="104" y1="50" x2="166" y2="50" class="str" />
      <rect x="112" y="58" width="22" height="10" class="p-f" fill-opacity="0.2" />
      <rect x="138" y="58" width="22" height="10" class="acc-f" fill-opacity="0.3" />
      <rect x="112" y="74" width="22" height="10" class="p-f" fill-opacity="0.3" />
      <rect x="138" y="74" width="22" height="10" class="p-f" fill-opacity="0.2" />
      <rect x="112" y="90" width="48" height="10" class="acc-f" fill-opacity="0.5" />
      <rect x="100" y="18" width="66" height="16" rx="8" class="p-f" />
      <text x="133" y="29" class="tag" fill="var(--accent)" text-anchor="middle">{t.currency_short}</text>
    </svg>
  )}

  {step === 4 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <line x1="30" y1="20" x2="30" y2="120" class="str thin" />
      <line x1="30" y1="120" x2="160" y2="120" class="str thin" />
      <rect x="42" y="40" width="16" height="80" class="p-f" opacity="0.85" />
      <rect x="68" y="55" width="16" height="65" class="p-f" opacity="0.7" />
      <rect x="94" y="75" width="16" height="45" class="acc-f" />
      <rect x="120" y="95" width="16" height="25" class="er-f" opacity="0.85" />
      <rect x="146" y="65" width="16" height="55" class="p-f" opacity="0.7" />
      <text x="50" y="35" class="val" text-anchor="middle">184</text>
      <text x="76" y="50" class="val" text-anchor="middle">142</text>
      <text x="102" y="70" class="val val-a" text-anchor="middle">62</text>
      <text x="128" y="90" class="val" text-anchor="middle" fill="var(--danger)">12</text>
      <text x="154" y="60" class="val" text-anchor="middle">98</text>
      <line x1="42" y1="120" x2="42" y2="123" class="str thin" />
      <line x1="68" y1="120" x2="68" y2="123" class="str thin" />
      <line x1="94" y1="120" x2="94" y2="123" class="str thin" />
      <line x1="120" y1="120" x2="120" y2="123" class="str thin" />
      <line x1="146" y1="120" x2="146" y2="123" class="str thin" />
    </svg>
  )}

  {step === 5 && (
    <svg viewBox="0 0 180 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <rect x="14" y="18" width="152" height="104" rx="6" class="str sfs" />
      <rect x="14" y="18" width="152" height="18" class="p-f" />
      <circle cx="24" cy="27" r="3" class="acc-f" />
      <rect x="32" y="24" width="40" height="6" class="acc-f" opacity="0.5" />
      <rect x="22" y="46" width="32" height="22" rx="3" class="str thin" fill="var(--surface-2)" />
      <text x="38" y="60" class="val" text-anchor="middle" fill="var(--primary)">26</text>
      <rect x="58" y="46" width="32" height="22" rx="3" class="str thin" fill="var(--surface-2)" />
      <text x="74" y="60" class="val-a val" text-anchor="middle">{t.value_short}</text>
      <rect x="94" y="46" width="32" height="22" rx="3" class="str thin" fill="var(--surface-2)" />
      <text x="110" y="60" class="val" text-anchor="middle" fill="var(--warn)">8</text>
      <rect x="130" y="46" width="28" height="22" rx="3" class="str thin" fill="var(--surface-2)" />
      <text x="144" y="60" class="val" text-anchor="middle" fill="var(--danger)">3</text>
      <polyline points="22,106 40,96 58,100 76,88 94,92 112,80 130,85 148,72 158,78" class="str acc" stroke-width="2" fill="none" />
      <circle cx="158" cy="78" r="3" class="acc-f" />
    </svg>
  )}
</div>

<style>
  .wf-illus { width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; }
  .wf-illus svg { width: 100%; height: 100%; max-width: 420px; max-height: 240px; }
  .wf-illus :global(.str) { stroke: var(--primary); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .wf-illus :global(.thin) { stroke-width: 1.5; }
  .wf-illus :global(.acc) { stroke: var(--accent); }
  .wf-illus :global(.acc-f) { fill: var(--accent); }
  .wf-illus :global(.p-f) { fill: var(--primary); }
  .wf-illus :global(.dim-f) { fill: var(--line); }
  .wf-illus :global(.sfs) { fill: var(--surface); }
  .wf-illus :global(.ok-f) { fill: var(--success); }
  .wf-illus :global(.wa-f) { fill: var(--warn); }
  .wf-illus :global(.er-f) { fill: var(--danger); }
  .wf-illus :global(.tag) { font-family: 'Roboto Condensed', ui-sans-serif, sans-serif; font-size: 9px; font-weight: 700; fill: var(--primary); letter-spacing: 0.05em; }
  .wf-illus :global(.val) { font-family: 'Roboto Condensed', ui-sans-serif, sans-serif; font-size: 10px; font-weight: 700; fill: var(--primary); }
  .wf-illus :global(.val-a) { fill: var(--accent); }
</style>
