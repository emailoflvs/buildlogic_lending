---
import inside from '../../content/inside.json';
import { type Locale, DEFAULT_LOCALE } from '../../lib/i18n';
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const c = inside[locale].audit;
---
<div class="mod mod-audit">
  <div class="mod-head">
    <div class="mod-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
    </div>
    <div><h3>{c.title}</h3></div>
  </div>
  <span class="live-badge">{c.live_label}</span>
  <div class="mod-preview">
    <div class="audit-list">
      {c.events.map((ev) => (
        <div class="audit-row">
          <span class="time">{ev.time}</span>
          <span class={`dot dot--${ev.dot}`}></span>
          <span class="text"><b>{ev.role}</b> {ev.action}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .mod-audit {
    position: relative;
  }

  .live-badge {
    position: absolute;
    top: 14px;
    right: 16px;
    font-family: var(--bl-font-mono);
    font-size: 10px;
    color: var(--bl-ok);
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
  }
  .live-badge::before {
    content: '●';
    margin-right: 4px;
    display: inline-block;
    animation: audit-pulse 1.5s infinite;
  }

  @keyframes audit-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.35; transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-badge::before { animation: none; }
  }

  .audit-list {
    display: flex;
    flex-direction: column;
    padding: 10px 14px;
    gap: 0;
  }
  .audit-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    border-bottom: 1px solid var(--bl-card-stroke);
    font-size: 12px;
  }
  .audit-row:last-child {
    border-bottom: none;
  }
  .time {
    font-family: var(--bl-font-mono);
    font-size: 10px;
    color: var(--bl-muted);
    min-width: 38px;
    flex-shrink: 0;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot--ok     { background: var(--bl-ok); }
  .dot--accent { background: var(--bl-accent); }
  .dot--def    { background: var(--bl-def); }

  .text {
    color: var(--bl-ink-2);
    font-size: 11px;
    line-height: 1.4;
  }
  .text b {
    color: var(--bl-green);
    font-weight: 600;
  }
</style>
