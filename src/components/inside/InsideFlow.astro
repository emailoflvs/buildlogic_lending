---
import inside from '../../content/inside.json';
import { type Locale, DEFAULT_LOCALE } from '../../lib/i18n';
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const c = inside[locale].flow;

const icons: Record<string, string> = {
  delivery: 'M16 3h5v13h-5zM1 3h15v13H1zM5 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm13 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z',
  accept:   'M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  stock:    'M3 7h18v4H3zM3 13h18v4H3zM5 7V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2',
  in_use:   'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
};
---
<div class="mod mod-flow">
  <div class="mod-head">
    <div class="mod-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V9l8-6 8 6v12M9 21V13h6v8"/></svg>
    </div>
    <div><h3>{c.title}</h3><p>{c.body}</p></div>
  </div>
  <div class="mod-preview">
    <div class="flow-stages">
      {c.stages.map((stage, i) => (
        <>
          <div class={`stage-cell${stage.active ? ' stage-cell--active' : ''}`}>
            <div class={`stage-icon${stage.active ? ' stage-icon--active' : ''}`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[stage.key]} />
              </svg>
            </div>
            <span class="stage-label">{stage.label}</span>
            <span class="stage-count">{stage.count}</span>
          </div>
          {i < c.stages.length - 1 && <span class="stage-arrow">→</span>}
        </>
      ))}
    </div>
    <div class="flow-stats">
      {c.stats.map((s) => (
        <div class={`flow-stat${s.mod ? ` flow-stat--${s.mod}` : ''}`}>
          <b>{s.value}</b>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </div>
  <div class="flow-plashka">
    <span class="plashka-dot"></span>
    <span class="plashka-text">{c.last_event.prefix} <b>{c.last_event.material}</b> · {c.last_event.qty}</span>
    <span class="plashka-time">{c.last_event.time}</span>
  </div>
</div>

<style>
  .flow-stages {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    gap: 4px;
    align-items: center;
    padding: 14px 12px 10px;
  }
  .stage-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .stage-icon {
    width: 24px;
    height: 24px;
    border-radius: 5px;
    background: var(--bl-paper-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--bl-ink-2);
    flex-shrink: 0;
  }
  .stage-icon--active {
    background: var(--bl-accent);
    color: #fff;
  }
  .stage-label {
    font-size: 9px;
    color: var(--bl-muted);
    text-align: center;
    line-height: 1.2;
    font-family: var(--bl-font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stage-cell--active .stage-label {
    color: var(--bl-accent-ink);
    font-weight: 600;
  }
  .stage-count {
    font-family: var(--bl-font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--bl-ink);
    line-height: 1;
  }
  .stage-cell--active .stage-count {
    color: var(--bl-accent-ink);
  }
  .stage-arrow {
    color: var(--bl-accent-ink);
    font-size: 12px;
    justify-self: center;
  }

  .flow-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px dashed var(--bl-card-stroke);
    padding: 8px 0 6px;
  }
  .flow-stat {
    padding: 6px 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .flow-stat + .flow-stat {
    border-left: 1px solid var(--bl-card-stroke);
  }
  .flow-stat b {
    font-family: var(--bl-font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1;
    color: var(--bl-ink);
  }
  .flow-stat span {
    font-size: 10px;
    color: var(--bl-muted);
    line-height: 1.3;
  }
  .flow-stat--accent b { color: var(--bl-accent-ink); }
  .flow-stat--ok b { color: var(--bl-ok); }

  .flow-plashka {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bl-paper-2);
    border: 1px solid rgba(42,74,66,0.25);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 11px;
    color: var(--bl-ink-2);
    margin-top: auto;
  }
  .plashka-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bl-ok);
    flex-shrink: 0;
  }
  .plashka-text {
    flex: 1;
    min-width: 0;
  }
  .plashka-text b {
    color: var(--bl-ink);
    font-weight: 600;
  }
  .plashka-time {
    font-family: var(--bl-font-mono);
    font-size: 10px;
    color: var(--bl-muted);
    background: var(--bl-card);
    border: 1px solid var(--bl-card-stroke);
    border-radius: 4px;
    padding: 2px 6px;
    flex-shrink: 0;
  }
</style>
