---
import inside from '../../content/inside.json';
import { type Locale, DEFAULT_LOCALE } from '../../lib/i18n';
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const c = inside[locale].docs;
---
<div class="mod mod-docs">
  <div class="mod-head">
    <div class="mod-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l5 5v13a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm7 0v5h5"/></svg>
    </div>
    <div><h3>{c.title}</h3><p>{c.body}</p></div>
  </div>
  <div class="mod-preview docs-grid">
    {c.formats.map((f) => (
      <div class="paper-wrap">
        <div class={`paper-thumb${f.signed ? ' paper-thumb--signed' : ''}`}>
          <span class="line" style="width:60%"></span>
          <span class="line" style="width:80%"></span>
          <span class="line" style="width:50%"></span>
          <span class="line" style="width:70%"></span>
          {f.signed && <span class="ok-stamp">OK</span>}
        </div>
        <div class="paper-fmt">{f.fmt}</div>
        <div class="paper-hint">{f.hint}</div>
      </div>
    ))}
  </div>
</div>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    padding: 14px;
  }
  .paper-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .paper-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: #fff;
    border: 1px solid var(--bl-card-stroke);
    border-radius: 5px;
    padding: 10px 8px 8px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
  }
  /* folded corner */
  .paper-thumb::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 14px;
    height: 14px;
    background: linear-gradient(225deg, var(--bl-card-stroke) 50%, transparent 50%);
  }
  .line {
    display: block;
    height: 4px;
    border-radius: 2px;
    background: var(--bl-accent-soft);
  }
  .ok-stamp {
    position: absolute;
    bottom: 8px;
    right: 7px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid var(--bl-def);
    color: var(--bl-def);
    font-family: var(--bl-font-mono);
    font-size: 7px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(-12deg);
    letter-spacing: 0.05em;
  }
  .paper-fmt {
    font-family: var(--bl-font-display);
    font-size: 11px;
    color: var(--bl-ink);
    font-weight: 500;
    text-align: center;
    line-height: 1.3;
  }
  .paper-hint {
    font-family: var(--bl-font-mono);
    font-size: 8px;
    color: var(--bl-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
  }
</style>
