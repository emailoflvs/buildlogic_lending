---
import illus from '../../content/illus.json';
import { type Locale, DEFAULT_LOCALE } from '../../lib/i18n';
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const steps = illus[locale].hero_steps;
const heroDash = illus[locale].hero_dash;
---
<div class="hero-kpi" data-hero-kpi>
  <div class="kpi-head">
    <span>{heroDash.working_contour}</span>
    <span>{heroDash.period}</span>
  </div>
  <div class="kpi-title-row">
    <h3 class="kpi-title" data-kpi-title>{steps[0].title}</h3>
    <span class="kpi-status" data-kpi-status>● {steps[0].status}</span>
  </div>
  <div class="kpi-tiles" data-kpi-tiles>
    {steps[0].tiles.map((tile) => (
      <div class={`kpi-tile${tile.mod ? ' kpi-tile--' + tile.mod : ''}`}>
        <div class="kpi-tile-label">{tile.l}</div>
        <div class="kpi-tile-num">{tile.n}</div>
        <div class="kpi-tile-hint">{tile.h}</div>
      </div>
    ))}
  </div>
  <div class="kpi-steps" role="tablist">
    {steps.map((s, i) => (
      <button
        type="button"
        class={`kpi-step${i === 0 ? ' kpi-step--active' : ''}`}
        data-step-idx={i}
        role="tab"
        aria-selected={i === 0}
      >
        <span class="kpi-step-num">{String(i + 1).padStart(2, '0')}</span>
        <span class="kpi-step-label">{s.label}</span>
      </button>
    ))}
  </div>

  {steps[0].rows && (
    <div class="kpi-rows" data-kpi-rows>
      <div class="kpi-row kpi-row--head" data-kpi-rows-head>
        <span>{steps[0].rows.headers[0]}</span>
        <span>{steps[0].rows.headers[1]}</span>
        <span>{steps[0].rows.headers[2]}</span>
      </div>
      {steps[0].rows.items.map((item) => (
        <div class="kpi-row">
          <span class="kpi-row-c1">{item.c1}</span>
          <span class={`kpi-row-c2${item.mod ? ' kpi-row-c2--' + item.mod : ''}`}>{item.c2}</span>
          <span class="kpi-row-c3">{item.c3}</span>
        </div>
      ))}
    </div>
  )}
</div>

<script is:inline define:vars={{ steps }}>
  (function () {
    const card = document.querySelector('[data-hero-kpi]');
    if (!card) return;
    const titleEl = card.querySelector('[data-kpi-title]');
    const statusEl = card.querySelector('[data-kpi-status]');
    const tilesEl = card.querySelector('[data-kpi-tiles]');
    const stepBtns = card.querySelectorAll('[data-step-idx]');
    let idx = 0;
    let timer = null;
    let paused = false;

    // Cache tile element references and their scoped-style-safe inner spans.
    // We MUTATE existing SSR-rendered tiles rather than re-innerHTML them, so
    // Astro's scoped-CSS data attributes survive across step changes.
    const tileEls = tilesEl.querySelectorAll('.kpi-tile');
    const tileParts = Array.from(tileEls).map((el) => ({
      root: el,
      label: el.querySelector('.kpi-tile-label'),
      num: el.querySelector('.kpi-tile-num'),
      hint: el.querySelector('.kpi-tile-hint'),
    }));

    // rows section (optional — present only if data has `rows`)
    const rowsEl = card.querySelector('[data-kpi-rows]');
    const rowsHeadEl = card.querySelector('[data-kpi-rows-head]');
    const rowEls = rowsEl ? rowsEl.querySelectorAll('.kpi-row:not(.kpi-row--head)') : [];
    const rowParts = Array.from(rowEls).map((el) => ({
      root: el,
      c1: el.querySelector('.kpi-row-c1'),
      c2: el.querySelector('.kpi-row-c2'),
      c3: el.querySelector('.kpi-row-c3'),
    }));

    function renderStep(i) {
      const s = steps[i];
      titleEl.textContent = s.title;
      statusEl.textContent = '● ' + s.status;
      s.tiles.forEach((t, j) => {
        const parts = tileParts[j];
        if (!parts) return;
        parts.root.className = 'kpi-tile' + (t.mod ? ' kpi-tile--' + t.mod : '');
        parts.label.textContent = t.l;
        parts.num.textContent = t.n;
        parts.hint.textContent = t.h;
      });
      if (s.rows && rowsHeadEl) {
        const headSpans = rowsHeadEl.querySelectorAll('span');
        headSpans[0].textContent = s.rows.headers[0];
        headSpans[1].textContent = s.rows.headers[1];
        headSpans[2].textContent = s.rows.headers[2];
        s.rows.items.forEach((item, j) => {
          const parts = rowParts[j];
          if (!parts) return;
          parts.c1.textContent = item.c1;
          parts.c2.textContent = item.c2;
          parts.c2.className = 'kpi-row-c2' + (item.mod ? ' kpi-row-c2--' + item.mod : '');
          parts.c3.textContent = item.c3;
        });
      }
      stepBtns.forEach((btn, j) => {
        const active = j === i;
        btn.classList.toggle('kpi-step--active', active);
        btn.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function tick() {
      if (paused) return;
      idx = (idx + 1) % steps.length;
      renderStep(idx);
    }

    function start() {
      stop();
      timer = setInterval(tick, 3200);
    }
    function stop() { if (timer) clearInterval(timer); timer = null; }

    card.addEventListener('mouseenter', () => { paused = true; });
    card.addEventListener('mouseleave', () => { paused = false; });

    stepBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        idx = Number(btn.dataset.stepIdx);
        renderStep(idx);
        paused = true;
        setTimeout(() => { paused = false; }, 6000);
      });
    });

    const tablistEl = card.querySelector('[role="tablist"]');
    if (tablistEl) {
      tablistEl.addEventListener('keydown', (e) => {
        if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(e.key)) return;
        e.preventDefault();
        const btns = [...stepBtns];
        const cur = btns.findIndex((b) => b.getAttribute('aria-selected') === 'true');
        let next;
        if (e.key === 'ArrowRight') next = (cur + 1) % btns.length;
        else if (e.key === 'ArrowLeft') next = (cur - 1 + btns.length) % btns.length;
        else if (e.key === 'Home') next = 0;
        else next = btns.length - 1;
        idx = next;
        renderStep(idx);
        btns[next].focus();
        paused = true;
        setTimeout(() => { paused = false; }, 6000);
      });
    }

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      start();
    }
  })();
</script>

<style>
  .hero-kpi {
    background: var(--bl-card);
    border: 1px solid var(--bl-card-stroke);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    box-shadow: 0 30px 70px -30px rgba(31, 59, 52, 0.35);
    position: relative;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }
  .kpi-head {
    display: flex;
    justify-content: space-between;
    font-family: var(--bl-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bl-muted);
    margin-bottom: 10px;
  }
  .kpi-title-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 18px; }
  .kpi-title { font-family: var(--bl-font-display); font-size: 24px; font-weight: 500; letter-spacing: -0.02em; margin: 0; color: var(--bl-ink); }
  .kpi-status { padding: 4px 10px; border-radius: 999px; background: var(--bl-accent-soft); color: var(--bl-accent-ink); font-size: 11px; font-weight: 600; white-space: nowrap; }
  .kpi-tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .kpi-tile {
    border: 1px solid var(--bl-card-stroke);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    background: linear-gradient(135deg, var(--bl-paper) 0%, var(--bl-paper-2) 100%);
    transition: background 0.35s var(--bl-ease), border-color 0.35s var(--bl-ease);
  }
  .kpi-tile-label { font-family: var(--bl-font-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bl-muted); }
  .kpi-tile-num { font-family: var(--bl-font-display); font-size: 24px; font-weight: 500; color: var(--bl-ink); letter-spacing: -0.02em; margin: 4px 0 2px; }
  .kpi-tile-hint { font-size: 11px; color: var(--bl-muted); }
  .kpi-tile--warn {
    background: linear-gradient(135deg, #fceeea 0%, #f5dfdb 100%);
    border-color: #e8b9b5;
  }
  .kpi-tile--warn .kpi-tile-num { color: var(--bl-def); }
  .kpi-tile--ok {
    background: linear-gradient(135deg, #e7f1e7 0%, #d5e6d5 100%);
    border-color: #b5d5b5;
  }
  .kpi-tile--ok .kpi-tile-num { color: var(--bl-ok); }
  .kpi-tile--accent {
    background: linear-gradient(135deg, rgba(201, 142, 79, 0.12) 0%, rgba(201, 142, 79, 0.22) 100%);
    border-color: rgba(201, 142, 79, 0.5);
  }
  .kpi-tile--accent .kpi-tile-num { color: var(--bl-accent-ink); }
  .kpi-steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: 5px; margin-top: 16px; }
  .kpi-step {
    padding: 10px 8px; border-radius: 8px; border: 1px solid var(--bl-card-stroke);
    background: transparent; color: var(--bl-ink-2); cursor: pointer;
    display: flex; flex-direction: column; gap: 3px;
    transition: all 0.35s var(--bl-ease);
    text-align: left;
    font-family: inherit;
  }
  .kpi-step--active { background: var(--bl-accent-soft); border-color: var(--bl-accent); color: var(--bl-accent-ink); transform: scale(1.03); }
  .kpi-step-num { font-family: var(--bl-font-mono); font-size: 10px; color: var(--bl-muted); }
  .kpi-step--active .kpi-step-num { color: var(--bl-accent-ink); }
  .kpi-step-label { font-size: 11px; font-weight: 600; }
  .kpi-step:focus-visible {
    outline: 2px solid var(--bl-accent);
    outline-offset: 2px;
  }

  .kpi-rows {
    margin-top: 16px;
    border-top: 1px solid var(--bl-card-stroke);
    padding-top: 12px;
    display: grid;
    gap: 0;
  }
  .kpi-row {
    display: grid;
    grid-template-columns: 1.2fr 1.1fr 1fr;
    gap: 10px;
    padding: 10px 4px;
    border-bottom: 1px solid var(--bl-card-stroke);
    align-items: center;
  }
  .kpi-row:last-child { border-bottom: none; }
  .kpi-row--head {
    font-family: var(--bl-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bl-muted);
    padding: 6px 4px;
  }
  .kpi-row-c1 { font-size: 12px; color: var(--bl-ink); font-weight: 500; }
  .kpi-row-c2 { font-size: 12px; color: var(--bl-ink); font-weight: 600; }
  .kpi-row-c2--ok { color: var(--bl-ok); }
  .kpi-row-c2--warn { color: var(--bl-def); }
  .kpi-row-c2--accent { color: var(--bl-accent-ink); }
  .kpi-row-c3 { font-size: 11px; color: var(--bl-muted); }

  @media (max-width: 420px) {
    .kpi-rows { margin-top: 12px; padding-top: 10px; }
    .kpi-row { padding: 8px 2px; gap: 6px; grid-template-columns: 1.1fr 1fr 0.9fr; }
    .kpi-row--head { font-size: 8px; }
    .kpi-row-c1, .kpi-row-c2 { font-size: 11px; }
    .kpi-row-c3 { font-size: 10px; }
  }

  /* Narrow mobile — tighten everything so the card fits in ~320px viewports */
  @media (max-width: 420px) {
    .hero-kpi { padding: var(--space-4); }
    .kpi-title { font-size: 18px; }
    .kpi-status { font-size: 10px; padding: 3px 8px; }
    .kpi-tiles { gap: 6px; }
    .kpi-tile { padding: 10px; }
    .kpi-tile-num { font-size: 18px; word-break: break-word; }
    .kpi-tile-hint { font-size: 10px; }
    .kpi-steps { gap: 3px; margin-top: 12px; }
    .kpi-step { padding: 8px 4px; min-width: 0; overflow: hidden; }
    .kpi-step-label {
      font-size: 10px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }
</style>
