---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CookieBanner from '../../components/CookieBanner.astro';
import Hero from '../../components/Hero.astro';
import RoleStrip from '../../components/RoleStrip.astro';
import Problems from '../../components/Problems.astro';
import Overview from '../../components/Overview.astro';
import Workflow from '../../components/Workflow.astro';
import Inside from '../../components/Inside.astro';
import Why from '../../components/Why.astro';
import Pricing from '../../components/Pricing.astro';
import FAQ from '../../components/FAQ.astro';
import Contact from '../../components/Contact.astro';
---
<BaseLayout title="BuildLogic — Контроль материалов по объекту" description="BuildLogic помогает строительной компании держать под контролем объект, документы, приход материалов, остатки и итоговый отчёт." path="/">
  <Header path="/" />
  <main>
    <Hero />
    <RoleStrip />
    <Problems />
    <Overview />
    <Workflow />
    <Inside />
    <Why />
    <Pricing />
    <FAQ />
    <Contact />
  </main>
  <Footer />
  <CookieBanner />
</BaseLayout>
