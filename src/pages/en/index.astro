---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CookieBanner from '../../components/CookieBanner.astro';
import Hero from '../../components/Hero.astro';
import RoleStrip from '../../components/RoleStrip.astro';
import Problems from '../../components/Problems.astro';
import Overview from '../../components/Overview.astro';
import Workflow from '../../components/Workflow.astro';
import Inside from '../../components/Inside.astro';
---
<BaseLayout title="BuildLogic — Material control on site" description="BuildLogic helps construction companies control objects, documents, material inflow and remainders." path="/">
  <Header path="/" />
  <main>
    <Hero />
    <RoleStrip />
    <Problems />
    <Overview />
    <Workflow />
    <Inside />
  </main>
  <Footer />
  <CookieBanner />
</BaseLayout>
